rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // summaries: 분석 결과 - 누구나 읽기/생성, 수정 금지, 삭제는 허용 (관리자 API에서 캐시 초기화용)
    match /summaries/{sessionId} {
      allow read: if true;
      allow create: if true;
      allow update: if false;
      allow delete: if true;
    }

    // saved_summaries: 본인, 공개 항목, 또는 '친구' 관계인 경우 읽기 허용
    match /saved_summaries/{docId} {
      allow read: if resource.data.isPublic == true
                  || (request.auth != null && (
                      request.auth.uid == resource.data.userId ||
                      request.auth.token.email == resource.data.userId ||
                      exists(/databases/$(database)/documents/friendships/$(request.auth.uid < resource.data.userId ? request.auth.uid + '_' + resource.data.userId : resource.data.userId + '_' + request.auth.uid))
                  ));
      allow create: if request.auth != null;
      allow delete, update: if request.auth != null && (request.auth.uid == resource.data.userId || request.auth.token.email == resource.data.userId);
    }

    // folders: 본인 폴더 읽기/쓰기, 공개 항목 또는 친구 관계인 경우 읽기 허용
    match /folders/{docId} {
      allow read: if resource.data.visibility == 'public'
                  || (request.auth != null && (
                      request.auth.uid == resource.data.userId ||
                      request.auth.token.email == resource.data.userId ||
                      exists(/databases/$(database)/documents/friendships/$(request.auth.uid < resource.data.userId ? request.auth.uid + '_' + resource.data.userId : resource.data.userId + '_' + request.auth.uid))
                  ));
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && (request.auth.uid == resource.data.userId || request.auth.token.email == resource.data.userId);
    }

    // likes: 본인 좋아요만 생성/삭제, 읽기는 누구나
    match /likes/{likeId} {
      allow read: if true;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
      allow delete: if request.auth != null && request.auth.uid == resource.data.userId;
    }

    // users: 프로필 공개 읽기, 본인만 쓰기
    match /users/{uid} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == uid;

      match /yt_playlists/{playlistId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;

        match /videos/{videoId} {
          allow read, write: if request.auth != null && request.auth.uid == uid;
        }
      }
    }

    // comments: 누구나 읽기, 로그인 유저만 작성, 본인만 삭제
    // isAI == true 인 댓글은 서버 API에서 생성 (userId 체크 없이 허용)
    match /comments/{commentId} {
      allow read: if true;
      allow create: if (request.auth != null && request.auth.uid == request.resource.data.userId)
                   || request.resource.data.isAI == true;
      allow delete: if request.auth != null && request.auth.uid == resource.data.userId;
    }

    // watch_rooms: 시청파티 방 — 누구나 읽기/생성, 참여자 업데이트 허용 (익명 포함)
    match /watch_rooms/{roomId} {
      allow read: if true;
      allow create: if true;
      allow update: if true;
      allow delete: if false;

      match /messages/{msgId} {
        allow read: if true;
        allow create: if true;
        allow update, delete: if false;
      }

      match /polls/{pollId} {
        allow read: if true;
        allow create: if true;
        allow update: if true;
        allow delete: if false;
      }
    }

    // conversations: 참여자만 읽기/쓰기 (방 생성 전 존재 확인을 위해 ID 기반 조회 허용)
    match /conversations/{cid} {
      allow read: if request.auth != null && (
        request.auth.uid in cid.split('_') ||
        (resource != null && request.auth.uid in resource.data.participants)
      );
      allow create: if request.auth != null && request.auth.uid in request.resource.data.participants;
      allow update: if request.auth != null && request.auth.uid in resource.data.participants;

      match /messages/{msgId} {
        allow read: if request.auth != null && request.auth.uid in cid.split('_');
        allow create: if request.auth != null && request.auth.uid in cid.split('_') && request.auth.uid == request.resource.data.senderId;
      }
    }

    // friend_requests: 쿼리(검색) 및 개별 조회를 위해 필드 기반 권한 추가
    match /friend_requests/{reqId} {
      allow read: if request.auth != null && (
        request.auth.uid in reqId.split('_') ||
        (resource != null && (request.auth.uid == resource.data.fromUid || request.auth.uid == resource.data.toUid))
      );
      allow create: if request.auth != null && request.auth.uid == request.resource.data.fromUid;
      allow update, delete: if request.auth != null && (request.auth.uid == resource.data.fromUid || request.auth.uid == resource.data.toUid);
    }
    // friendships: 쿼리(array-contains) 및 개별 조회를 위해 필드 기반 권한 추가
    match /friendships/{fid} {
      allow read: if request.auth != null && (
        request.auth.uid in fid.split('_') ||
        (resource != null && request.auth.uid in resource.data.uids)
      );
      allow create: if request.auth != null && request.auth.uid in request.resource.data.uids;
      allow delete: if request.auth != null && request.auth.uid in resource.data.uids;
    }

    // shared_folders: 링크가 있으면 읽기 가능, 생성은 로그인 유저
    match /shared_folders/{shareId} {
      allow read: if true;
      allow create: if request.auth != null;
    }

    // classes: 누구나 읽기 (서버 API에서 코드 확인용), 서버 API 생성 허용, 교사만 수정/삭제
    match /classes/{classCode} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if request.auth != null && request.auth.uid == resource.data.teacherId;
    }

    // blog_drafts: 본인 블로그 초안 CRUD
    match /blog_drafts/{draftId} {
      allow read: if request.auth != null && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
      allow delete: if request.auth != null && request.auth.uid == resource.data.userId;
    }

    // shorts_scripts: 본인 숏폼 스크립트 CRUD
    match /shorts_scripts/{scriptId} {
      allow read: if request.auth != null && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
      allow delete: if request.auth != null && request.auth.uid == resource.data.userId;
    }

    // travel_regions: 본인 지역 폴더 CRUD
    match /travel_regions/{regionId} {
      allow read: if request.auth != null && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
      allow update, delete: if request.auth != null && request.auth.uid == resource.data.userId;
    }

    // travel_spots: 본인 스팟 CRUD
    match /travel_spots/{spotId} {
      allow read: if request.auth != null && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
      allow update, delete: if request.auth != null && request.auth.uid == resource.data.userId;
    }

    // travel_itineraries: 본인 AI 여행 일정 저장
    match /travel_itineraries/{itineraryId} {
      allow read: if request.auth != null && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
      allow delete: if request.auth != null && request.auth.uid == resource.data.userId;
    }

    // video_bookmarks: 본인 타임스탬프 북마크
    match /video_bookmarks/{bookmarkId} {
      allow read: if request.auth != null && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
      allow delete: if request.auth != null && request.auth.uid == resource.data.userId;
    }

    // activity_logs: 학생 본인 생성, 본인 및 담당 교사 읽기
    match /activity_logs/{logId} {
      allow create: if request.auth != null && request.auth.uid == request.resource.data.studentId;
      allow read: if request.auth != null && (
        request.auth.uid == resource.data.studentId ||
        (resource != null &&
         exists(/databases/$(database)/documents/classes/$(resource.data.classCode)) &&
         get(/databases/$(database)/documents/classes/$(resource.data.classCode)).data.teacherId == request.auth.uid)
      );
    }
  }
}
