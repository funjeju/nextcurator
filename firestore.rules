rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // summaries: 분석 결과 - 누구나 읽기, 생성은 허용(API 서버에서 클라이언트 SDK로 저장), 수정/삭제 금지
    match /summaries/{sessionId} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if false;
    }

    // saved_summaries: 사용자가 저장한 항목
    // 공개 항목(isPublic=true)은 누구나 읽기, 본인 항목만 쓰기/삭제
    match /saved_summaries/{docId} {
      allow read: if resource.data.isPublic == true
                  || (request.auth != null && request.auth.uid == resource.data.userId);
      allow create: if request.auth != null;
      allow delete: if request.auth != null && request.auth.uid == resource.data.userId;
      allow update: if request.auth != null && request.auth.uid == resource.data.userId;
    }

    // folders: 본인 폴더만 읽기/쓰기
    match /folders/{docId} {
      allow read, write: if request.auth != null && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null;
    }

    // likes: 본인 좋아요만 생성/삭제, 읽기는 누구나
    match /likes/{likeId} {
      allow read: if true;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
      allow delete: if request.auth != null && request.auth.uid == resource.data.userId;
    }

    // users: 프로필 공개 읽기, 본인만 쓰기
    match /users/{uid} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // comments: 누구나 읽기, 로그인 유저만 작성, 본인만 삭제
    match /comments/{commentId} {
      allow read: if true;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
      allow delete: if request.auth != null && request.auth.uid == resource.data.userId;
    }

    // watch_rooms: 시청파티 방 — 누구나 읽기/생성, 참여자 업데이트 허용 (익명 포함)
    match /watch_rooms/{roomId} {
      allow read: if true;
      allow create: if true;
      allow update: if true;
      allow delete: if false;

      match /messages/{msgId} {
        allow read: if true;
        allow create: if true;
        allow update, delete: if false;
      }

      match /polls/{pollId} {
        allow read: if true;
        allow create: if true;
        allow update: if true;
        allow delete: if false;
      }
    }

    // conversations: 참여자만 읽기/쓰기
    match /conversations/{cid} {
      allow read, write: if request.auth != null && request.auth.uid in resource.data.participants;
      allow create: if request.auth != null && request.auth.uid in request.resource.data.participants;

      match /messages/{msgId} {
        allow read: if request.auth != null &&
          request.auth.uid in get(/databases/$(database)/documents/conversations/$(cid)).data.participants;
        allow create: if request.auth != null &&
          request.auth.uid in get(/databases/$(database)/documents/conversations/$(cid)).data.participants &&
          request.auth.uid == request.resource.data.senderId;
      }
    }
  }
}
